        "@pothos/core": "^4.12.0",
        "@pothos/plugin-simple-objects": "^4.1.3",
        "@supabase/supabase-js": "^2.98.0",
        "axios": "^1.16.1",
        "better-auth": "^1.6.2",
        "bottleneck": "^2.19.5",
        "dataloader": "^2.2.3",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.2",
