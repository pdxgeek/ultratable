{
    "name": "service",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "nodemon --watch src --watch .env --ext ts --exec ts-node src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:generate": "drizzle-kit generate",
        "db:bootstrap": "ts-node src/scripts/bootstrap-migrations.ts",
        "db:migrate": "ts-node src/scripts/migrate.ts",
        "db:push": "drizzle-kit push",
        "db:reset": "ts-node src/scripts/wipe_and_seed.ts",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint ."
    },
    "keywords": [],
    "author": "",
