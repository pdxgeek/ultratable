# ──────────────────────────────────────────────────────────────
# UltraTable Service — Environment Variables
#
# DO NOT edit this file by hand for local development — run
#     npm run setup
# from the repo root. It interactively writes apps/service/.env
# with sane defaults and re-uses existing values on subsequent
# runs.
#
# This .example file documents every variable the service reads.
# ──────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────
# Runtime mode. Set to "production" in deployed environments.
# Controls: GraphiQL visibility, dev-login endpoint, log format.
NODE_ENV=development

# Server bind address and port.
HOST=0.0.0.0
PORT=8080

# ── Logging ──────────────────────────────────────────────────
# Controls log verbosity. Valid values: trace, debug, info, warn, error, fatal.
# Defaults to 'debug' in development for maximum visibility.
# In production, set to 'info' (recommended) or 'warn' to reduce noise.
# Debug-level messages are never persisted to the database — stdout only.
LOG_LEVEL=debug

# ── Database (Drizzle / PostgreSQL) ──────────────────────────
# Full Postgres connection string. Required.
#
# Supabase config IS Postgres config. There are three valid
# local setups, all driven by `npm run setup`:
#
#   1. DB_MODE=docker   — local postgres:16-alpine on :5432
#                         DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
#                         Supabase keys left blank; storage features off.
#
#   2. DB_MODE=supabase — hosted Supabase project
#                         DATABASE_URL points at the Supabase pooler/direct connection.
#                         SUPABASE_URL/keys filled in below.
#
#   3. DB_MODE=system   — bring-your-own Postgres
#                         You set DATABASE_URL. Supabase keys optional.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ── Supabase ─────────────────────────────────────────────────
# Used for storage (team/player graphics) and the Supabase SDK.
# Leave blank when running against a local Postgres container —
# graphics upload calls will fail at call time, but the rest of
# the service runs fine.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key: used server-side for storage uploads (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ── Football Data Provider ───────────────────────────────────
# API-Football key (https://www.api-football.com/).
# Optional in development: leave blank to start the service
# without upstream data. Sport-data endpoints will return 401
# from the provider until a key is set.
API_FOOTBALL_KEY=

# ── Authentication (Better Auth) ─────────────────────────────
# Secret for signing session cookies. Must be ≥32 chars. Required.
# `npm run setup` generates this automatically.
BETTER_AUTH_SECRET=your-secret-key-at-least-32-chars-long

# Base URL for the auth endpoints. In production, this is the service URL.
# Dev default: http://localhost:5174 (admin app — which is where users sign in).
BETTER_AUTH_URL=http://localhost:5174

# ── Google OAuth (optional) ──────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# Google sign-in is enabled only when BOTH variables are set; leaving them
# blank keeps email/password as the only sign-in method.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS / Security ─────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Dev default: allows localhost:5174 and localhost:5175 automatically.
#
# REQUIRED in production: apps/service, apps/admin, and apps/web ship as
# independent containers behind distinct hostnames. Every frontend origin that
# makes credentialed fetches to the service (GraphQL, /api/auth/*, Google
# sign-in redirects) must be listed here — Better Auth's `trustedOrigins`
# allowlist is built from this same env var, so an unlisted origin will be
# rejected during OAuth callbackURL validation.
#
# In production the session cookie is set with SameSite=None; Secure, so the
# service MUST be served over HTTPS for the cookie to survive cross-site
# fetches.
# ALLOWED_ORIGINS=https://ultratable.io,https://admin.ultratable.io
