talCount: syncRes.stats.totalCount,\n                        apiCallsCount: syncRes.stats.apiCallsCount,\n                        context: { leagueId, season }\n                    };\n                }\n                return { processedCount: 0, apiCallsCount: 0 };\n            });\n\n            const [execution] = await db.select().from(schema.jobExecutions)\n                .orderBy(desc(schema.jobExecutions.startedAt))\n                .limit(1);\n            return execution;\n        },\n    })\n);\n","usedDeprecatedRules":[]},{"filePath":"/Users/dave/workspace/ultratable/apps/service/src/scripts/apply_players_migration.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/dave/workspace/ultratable/apps/service/src/scripts/cleanup_bad_graphics.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":23,"column":17,"messageId":"unexpectedAny","endLine":23,"endColumn":20,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1049,1052],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1049,1052],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { db } from '../db';\nimport * as schema from '../db/schema';\nimport { eq } from 'drizzle-orm';\nimport { storageProvider } from '../providers/supabase-storage.provider';\n\nasync function run() {\n    console.log('Cleaning up invalid player graphic rows...');\n    try {\n        // Find all player graphics to delete their blobs if necessary\n        cons