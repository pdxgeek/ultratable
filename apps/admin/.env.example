# ──────────────────────────────────────────────────────────────
# UltraTable Admin — Environment Variables (Vite)
#
# DO NOT edit this file by hand for local development — run
#     npm run setup
# from the repo root. It writes a real apps/admin/.env alongside
# this one.
#
# Only VITE_* vars are exposed to the browser bundle. Anything
# secret MUST stay in apps/service/.env, never here.
# ──────────────────────────────────────────────────────────────

# ── Dev-server port ──────────────────────────────────────────
# Vite dev-server port. Read by apps/admin/vite.config.ts via loadEnv.
# Mirrors ADMIN_PORT in the root .env (setup.mjs writes both).
PORT=5174

# ── Google OAuth (optional) ──────────────────────────────────
# Public OAuth client ID for the admin app's Google sign-in. Bundled
# into the JS at build time — this is by design, client IDs are public.
# The matching client SECRET stays on the service (apps/service/.env)
# under GOOGLE_CLIENT_SECRET_ADMIN — it MUST NOT live here, because
# anything in apps/admin/.env ships to the browser.
#
# Register a Web OAuth client at https://console.cloud.google.com/apis/credentials
# with authorized JavaScript origin + redirect URI on the admin host
# (dev: http://localhost:5174 / prod: https://admin.ultratable.io).
VITE_GOOGLE_CLIENT_ID=
