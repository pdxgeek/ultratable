# ──────────────────────────────────────────────────────────────
# UltraTable Root — Shared dev tooling config.
#
# DO NOT edit this file by hand for local development — run
#     npm run setup
# from the repo root. It writes a real .env alongside this one.
# ──────────────────────────────────────────────────────────────

# ── Dev-server ports ─────────────────────────────────────────
# Source of truth for the three dev ports. Read by:
#   • scripts/start-all.js    — port-collision sweep + orphan kill
#   • scripts/wait-for-port.js — boot ordering
#   • health-check.sh         — npm run health:check
#   • docker-compose.yml      — service container (SERVICE_PORT only)
# Each runtime also reads its own port: apps/service/.env::PORT,
# apps/admin/.env::PORT, apps/web/.env::PORT. setup.mjs writes the
# same value to both places so they stay in lock-step.
SERVICE_PORT=8080
ADMIN_PORT=5174
WEB_PORT=5175

# ── API Target ───────────────────────────────────────────────
# URL the Vite dev server proxies /graphql and /api to.
# Default: http://127.0.0.1:${SERVICE_PORT}.
# In production (Vercel), the frontends call VITE_API_URL directly.
VITE_API_TARGET=http://127.0.0.1:8080

# Production-only: absolute API URL baked into the build.
# VITE_API_URL=https://api.ultratable.io

# ──────────────────────────────────────────────────────────────
# Service-side environment variables (DATABASE_URL, Supabase, etc.)
# live in apps/service/.env — see apps/service/.env.example.
# ──────────────────────────────────────────────────────────────
