# Better Auth Configuration
VITE_AUTH_SECRET=your-secret-key-at-least-32-chars-long
VITE_AUTH_BASE_URL=http://localhost:5174

# OAuth Configuration
# Get these by registering OAuth apps with each provider

# GitHub OAuth
# Register at: https://github.com/settings/developers
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Google OAuth
# Register at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Discord OAuth
# Register at: https://discord.com/developers/applications
VITE_DISCORD_CLIENT_ID=your_discord_client_id_here
VITE_DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Redirect URIs (for local development):
# - GitHub: http://localhost:5174/api/auth/callback/github
# - Google: http://localhost:5174/api/auth/callback/google
# - Discord: http://localhost:5174/api/auth/callback/discord
